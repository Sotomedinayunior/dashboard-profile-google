# ─────────────────────────────────────────────────────────────
# NELLY RAC / GROWTH DASHBOARD — Variables de entorno
# Copia este archivo como .env.local para desarrollo local
# En Vercel: Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Identidad del sitio ───────────────────────────────────────
# Nombre que aparece en el logo y títulos del dashboard
SITE_NAME=DualSym

# URL completa del sitio (con https:// y sin slash al final)
# Se usa también como propiedad de GSC si no defines GSC_PROPERTY
SITE_URL=https://www.dualsym.com

# ── Google Search Console ─────────────────────────────────────
# URL exacta de tu propiedad en GSC (cómo aparece en la consola)
# Puede ser con o sin www, con o sin slash — pon la exacta
# Si no lo defines, se usa SITE_URL
GSC_PROPERTY=https://www.dualsym.com/

# ── Google OAuth2 (Google Cloud Console) ─────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret

# Refresh token — obtenido visitando /api/auth una vez
GOOGLE_REFRESH_TOKEN=1//0your_refresh_token

# ── Google My Business ────────────────────────────────────────
# Formato: accounts/{account_id}/locations/{location_id}
# El /api/callback te lo muestra automáticamente al autorizar
GMB_LOCATION_NAME=accounts/123456789012/locations/987654321098
