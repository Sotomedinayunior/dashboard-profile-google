{
  "version": 2,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "functions": {
    "api/pagespeed.js": {
      "maxDuration": 60
    },
    "api/data.js": {
      "maxDuration": 30
    }
  }
}